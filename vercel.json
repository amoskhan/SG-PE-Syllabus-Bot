{
  "buildCommand": "vite build",
  "devCommand": "vite --port $PORT",
  "outputDirectory": "dist",
  "functions": {
    "api/claude.ts": { "maxDuration": 120 }
  },
  "crons": [
    {
      "path": "/api/summarise-progress",
      "schedule": "55 15 * * *"
    },
    {
      "path": "/api/daily-chat-archive",
      "schedule": "55 15 * * *"
    }
  ]
}
